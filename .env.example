# MongoDB connection for admin/customization data
MONGODB_URI="mongodb://username:password@host:27017/socialchat?authSource=admin"
MONGODB_DB="socialchat"

# Admin login secret/password. Use a strong random value in production.
ADMIN_SECRET="change-me"
ADMIN_SESSION_SECRET="change-me-at-least-32-chars"

# Optional default source for the OpenAPI sync button
DEFAULT_OPENAPI_SOURCE_URL="https://staging-api.socialchat.id/partner/explorer-json"
